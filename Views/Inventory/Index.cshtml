@model IEnumerable<AurHER.DTOs.Admin.InventoryItemDto>
@{
    ViewData["Title"] = "Inventory";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";

    var filter = ViewBag.Filter as string ?? "all";
     var totalCount = (int)(ViewBag.TotalCount ?? 0);
    var lowStockCount = (int)(ViewBag.LowStockCount ?? 0);
    var outOfStockCount = (int)(ViewBag.OutOfStockCount ?? 0);
    var itemCount = Model.Count();
}


@section Styles {
    <link rel="stylesheet" href="~/css/admin-inventory.css" asp-append-version="true" />
}

<!-- ── Page Header ── -->
<div class="page-actions animate-in">
    <div>
        <h1 class="page-title">Inventory</h1>
        <p class="page-subtitle">Track stock levels across all product variants</p>
    </div>
    <a href="/Product/Index" class="btn-edit" style="display:inline-flex;align-items:center;gap:6px;padding:10px 18px;background:var(--surface);border:1px solid var(--border-light);border-radius:var(--radius-sm);font-size:0.875rem;font-weight:600;color:var(--text-secondary);text-decoration:none;">
        <svg viewBox="0 0 24 24" style="width:15px;height:15px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;">
            <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 01-8 0"/>
        </svg>
        Manage Products
    </a>
</div>

<!-- ── Summary Cards ── -->
<div class="inventory-summary animate-in delay-1">

    <a href="/Inventory/Index?filter=all" class="summary-card all @(filter == "all" ? "active" : "")">
        <div class="summary-icon all">
            <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
        </div>
        <div class="summary-info">
            <div class="summary-count">@totalCount</div>
            <div class="summary-label">Total Variants</div>
        </div>
    </a>

    <a href="/Inventory/Index?filter=low" class="summary-card low @(filter == "low" ? "active" : "")">
        <div class="summary-icon low">
            <svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
        </div>
        <div class="summary-info">
            <div class="summary-count">@lowStockCount</div>
            <div class="summary-label">Low Stock</div>
        </div>
    </a>

    <a href="/Inventory/Index?filter=out" class="summary-card out @(filter == "out" ? "active" : "")">
        <div class="summary-icon out">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div class="summary-info">
            <div class="summary-count">@outOfStockCount</div>
            <div class="summary-label">Out of Stock</div>
        </div>
    </a>

</div>

<!-- ── Filter Tabs ── -->
<div class="filter-tabs animate-in delay-2">
    <a href="/Inventory/Index?filter=all" class="filter-tab @(filter == "all" ? "active" : "")">
        All Variants
        <span class="filter-tab-count">@totalCount</span>
    </a>
    <a href="/Inventory/Index?filter=low" class="filter-tab low @(filter == "low" ? "active low" : "")">
        Low Stock
        <span class="filter-tab-count">@lowStockCount</span>
    </a>
    <a href="/Inventory/Index?filter=out" class="filter-tab out @(filter == "out" ? "active out" : "")">
        Out of Stock
        <span class="filter-tab-count">@outOfStockCount</span>
    </a>
</div>

<!-- ── Search ── -->
<div class="inventory-search animate-in delay-2">
    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
    <input type="text"
           id="inventorySearch"
           placeholder="Search by product, SKU, size or color..." />
</div>

<!-- ── Inventory Table ── -->
<div class="table-card animate-in delay-3">
    <div class="table-header">
        <span class="table-title">
            @if (filter == "low") { <text>Low Stock Items</text> }
            else if (filter == "out") { <text>Out of Stock Items</text> }
            else { <text>All Stock</text> }
        </span>
        <span class="table-count" id="visibleCount">@itemCount items</span>
    </div>

    @if (Model.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Product</th>
                    <th>SKU</th>
                    <th>Variant</th>
                    <th>Quantity</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="inventory-row"
                        data-search="@item.ProductName @item.SKU @item.Size @item.Color @item.CategoryName">
                        <td>
                            <div class="product-name">@item.ProductName</div>
                            <div class="product-category">@(item.CategoryName ?? "No category")</div>
                        </td>
                        <td>
                            <span class="sku-code">@item.SKU</span>
                        </td>
                        <td>
                            <div class="variant-info">@item.Size · @item.Color</div>
                        </td>
                        <td>
                            <span class="stock-number @(item.StockQuantity == 0 ? "danger" : item.StockQuantity <= 5 ? "warning" : "success")">
                                @item.StockQuantity
                            </span>
                        </td>
                        <td>
                            <span class="stock-badge @(item.StockStatus == "Out of Stock" ? "out-of-stock" : item.StockStatus == "Low Stock" ? "low-stock" : "in-stock")">
                                <span class="stock-dot"></span>
                                @item.StockStatus
                            </span>
                        </td>
                        <td>
                            <a href="/Product/EditVariant/@item.VariantId" class="btn-edit-variant">
                                <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                Update Stock
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <svg class="empty-icon" viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
            <div class="empty-title">
                @if (filter == "low") { <text>No low stock items</text> }
                else if (filter == "out") { <text>No out of stock items</text> }
                else { <text>No inventory found</text> }
            </div>
            <div class="empty-subtitle">
                @if (filter == "all") { <text>Add products and variants to see inventory here</text> }
                else { <text>All variants are well stocked!</text> }
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/admin-inventory.js" asp-append-version="true"></script>
}
