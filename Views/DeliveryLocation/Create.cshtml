@model AurHER.Models.DeliveryLocation

@{
    ViewData["Title"] = "Add Delivery Location";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/delivery-location.css" />
}

<div class="page-actions animate-in">
    <div>
        <h1 class="page-title">Add Delivery Location</h1>
        <p class="page-subtitle">Add a new state or region with its delivery fee</p>
    </div>
</div>

<div class="form-card animate-in delay-1">
    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Name" class="form-label">Location / State</label>
            <input asp-for="Name" class="form-input" placeholder="e.g., Lagos-Ajah, Ibadan-Iwo-Road, Abeokouta" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Fee" class="form-label">Delivery Fee (₦)</label>
            <input asp-for="Fee" class="form-input" type="number" step="100" placeholder="e.g., 3000" />
            <span asp-validation-for="Fee" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Save Location</button>
            <a href="/DeliveryLocation/Create" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>