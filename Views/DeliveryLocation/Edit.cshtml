@model AurHER.Models.DeliveryLocation

@{
    ViewData["Title"] = "Edit Delivery Location";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/delivery-location.css" />
}

<div class="page-actions animate-in">
    <div>
        <h1 class="page-title">Edit Delivery Location</h1>
        <p class="page-subtitle">Update location name or delivery fee</p>
    </div>
</div>

<div class="form-card animate-in delay-1">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="form-group">
            <label asp-for="Name" class="form-label">Location / State</label>
            <input asp-for="Name" class="form-input" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="form-group">
            <label asp-for="Fee" class="form-label">Delivery Fee (₦)</label>
            <input asp-for="Fee" class="form-input" type="number" step="100" />
            <span asp-validation-for="Fee" class="text-danger"></span>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-primary">Save Changes</button>
            <a href="/DeliveryLocation/Index" class="btn-secondary">Cancel</a>
        </div>
    </form>
</div>