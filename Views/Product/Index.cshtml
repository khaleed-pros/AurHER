@model IEnumerable<AurHER.DTOs.Admin.ProductListDto>
@{
    ViewData["Title"] = "Products";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";

}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-products.css" asp-append-version="true" />
}

<!-- ── Page Header ── -->
<div class="page-actions animate-in">
                <div>
                    <h1 class="page-title">Products</h1>
                    <p class="page-subtitle">Manage your store products</p>
                </div>
                <a href="/Product/Create" class="btn-add">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Add Product
                </a>
            </div>

            <!-- ── Alerts ── -->
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success animate-in">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                    @TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-error animate-in">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    @TempData["ErrorMessage"]
                </div>
            }

            <!-- ── Products Table ── -->
            <div class="table-card animate-in delay-1">
                <div class="table-header">
                    <span class="table-title">All Products</span>
                    <span class="table-count">@Model.Count() total</span>
                </div>

                @if (Model.Any())
                {
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Product</th>
                                <th>Price Range</th>
                                <th>Variants</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model)
                            {
                                <tr>
                                    <td>
                                        <div class="product-row-info">
                                            <div class="product-thumb">
                                                @if (!string.IsNullOrEmpty(product.PrimaryImage))
                                                {
                                                    <img src="@product.PrimaryImage" alt="@product.Name" />
                                                }
                                                else
                                                {
                                                    <div class="product-thumb-placeholder">
                                                        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                                                    </div>
                                                }
                                            </div>
                                            <div>
                                                <div class="product-name">@product.Name</div>
                                                <div class="product-category">@(product.CategoryName ?? "No category")</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="price-range">
                                            @if (product.LowestPrice.HasValue)
                                            {
                                                @if (product.LowestPrice == product.HighestPrice)
                                                {
                                                    <span>₦@product.LowestPrice.Value.ToString("N0")</span>
                                                }
                                                else
                                                {
                                                    <span>₦@product.LowestPrice.Value.ToString("N0") — ₦@product.HighestPrice.Value.ToString("N0")</span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="no-price">No variants</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="variant-badge">@product.VariantCount variant@(product.VariantCount != 1 ? "s" : "")</span>
                                    </td>
                                    <td>
                                        <span class="status-badge @(product.IsActive ? "active" : "inactive")">
                                            <span class="status-dot"></span>
                                            @(product.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <div class="action-btns">
                                            <a href="/Product/Details/@product.Id" class="btn-details">
                                                <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                                Manage
                                            </a>
                                            <a href="/Product/Edit/@product.Id" class="btn-edit">
                                                <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                Edit
                                            </a>
                                            <form method="post" action="/Product/Toggle" style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@product.Id" />
                                                <button type="submit" class="btn-toggle @(product.IsActive ? "deactivate" : "activate")">
                                                    @(product.IsActive ? "Deactivate" : "Activate")
                                                </button>
                                            </form>
                                            <form method="post" action="/Product/Delete" class="delete-form" style="margin:0;">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@product.Id" />
                                                <button type="submit" class="btn-delete">
                                                    <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
                                                    Delete
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty-state">
                        <svg class="empty-icon" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                        <div class="empty-title">No products yet</div>
                        <div class="empty-subtitle">Click "Add Product" to create your first one</div>
                    </div>
                }
</div>

@section Scripts {
    <script src="~/js/admin-products.js" asp-append-version="true"></script>
}
