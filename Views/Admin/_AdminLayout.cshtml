<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — AurHER Admin</title>
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<div class="admin-wrapper">

    <!-- ── Sidebar ── -->
    <aside class="sidebar" id="adminSidebar">

        <!-- Brand -->
        <div class="sidebar-brand">
            
            <div class="brand-logo">
                <img src="~/images/aurher-logo.png" alt="AurHER Logo" 
                    style="width:36px;height:36px;object-fit:cover;border-radius:50%;display:block;" />
            </div>

            @* <span class="brand-name">Aur<span>HER</span></span> *@
            <span class="brand-name"><span class="brand-gold">Aur</span><span>HER</span></span>
        </div>

        <!-- Nav -->
        <nav class="sidebar-nav">

            <div class="nav-section-label">Main</div>

            <a href="/Admin/Dashboard" class="nav-item">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                </span>
                <span class="nav-label">Dashboard</span>
            </a>

            <div class="nav-section-label">Catalogue</div>

            <a href="/Product/Index" class="nav-item">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                </span>
                <span class="nav-label">Products</span>
            </a>

            <a href="/Category/Index" class="nav-item">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
                </span>
                <span class="nav-label">Categories</span>
            </a>

            <a href="/Collection/index" class="nav-item">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
                </span>
                <span class="nav-label">Collections</span>
            </a>

            <div class="nav-section-label">Orders</div>

            <a href="/Order/Index" class="nav-item">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="2"/><path d="M9 12h6M9 16h4"/></svg>
                </span>
                <span class="nav-label">Orders</span>
                @{
                    var pendingCount = ViewBag.PendingOrdersCount as int?;
                }
                @if (pendingCount.HasValue && pendingCount.Value > 0)
                {
                    <span class="nav-badge">@pendingCount</span>
                }
            </a>

            <div class="nav-section-label">Store</div>

            <a href="/Inventory/Index" class="nav-item">
                <span class="nav-icon">
                    <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
                </span>
                <span class="nav-label">Inventory</span>
            </a>
             <div class="nav-section-label">Delivery</div>
             <a href="/DeliveryLocation/Index" class="nav-item">
                    <span class="nav-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                        <circle cx="12" cy="10" r="3"/>
                    </svg>
                    </span>
                    <span class="nav-label">Location/Prices</span>
             </a>

        </nav>

        <!-- Profile -->
        <div class="sidebar-footer">
          
          <div class="admin-profile">
    <div class="profile-avatar">AD</div>
    <div class="profile-info">
        <div class="profile-name">Oyeronke</div>
        <div class="profile-role">Admin Panel</div>
    </div>
</div>
<form method="post" asp-controller="Admin" asp-action="Logout" 
      id="logoutForm"
      style="margin-top: 8px;">
    @Html.AntiForgeryToken()
    <button type="submit" class="nav-item" style="width:100%; border:none; cursor:pointer; background:transparent; color: var(--danger);">
        <span class="nav-icon">
            <svg viewBox="0 0 24 24">
                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                <polyline points="16 17 21 12 16 7"/>
                <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
        </span>
        <span class="nav-label">Logout</span>
    </button>
</form>
        </div>

    </aside>

    <!-- ── Main Content ── -->
    <div class="main-content" id="mainContent">

        <!-- Header -->
        <header class="admin-header">
            <button class="header-toggle" id="sidebarToggle" title="Toggle Sidebar">
                <svg viewBox="0 0 24 24">
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>

            <div class="header-breadcrumb">
                <span>Admin</span>
                <span class="breadcrumb-sep">›</span>
                <span class="breadcrumb-current">@ViewData["Title"]</span>
            </div>

            <div class="header-spacer"></div>

            <div class="header-actions">
            <span class="header-date" id="headerDate"></span>

            <!-- Dark Mode  -->
            <button class="header-btn" id="darkModeToggle" title="Toggle Dark Mode">
                <!-- Moon icon — shown in light mode -->
                <svg id="moonIcon" viewBox="0 0 24 24">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
                <!-- Sun icon — shown in dark mode -->
                <svg id="sunIcon" viewBox="0 0 24 24" style="display:none;">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
            </button>

                <button class="header-btn" title="Notifications">
                    <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
                    @if (pendingCount.HasValue && pendingCount.Value > 0)
                    {
                        <span class="notif-dot"></span>
                    }
                </button>
            </div>
        </header>

        <!-- Page Body -->
        <main class="page-content">
            @RenderBody()
        </main>

        <!-- Footer -->
        <footer class="admin-footer">
            <span class="footer-text">© @DateTime.Now.Year <span>AurHER</span> Admin Panel</span>
            <span class="footer-text">Dev. Khalid_Oyekunle</span>
        </footer>

    </div>
</div>
<!-- Mobile Sidebar Overlay -->
<div id="sidebarOverlay" 
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:99;"
     onclick="AdminPanel.closeMobileSidebar()">
</div>
<script src="~/js/admin.js" asp-append-version="true"></script>
<script src="~/js/charts.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)


</body>
</html>
