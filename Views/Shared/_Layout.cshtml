<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — AurHER</title>
    <meta name="description" content="@(ViewData["Description"] ?? "AurHER — Premium Women's Fashion")" />
    <link rel="stylesheet" href="~/css/store.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    
    <div class="announcement-bar">
        <div class="announcement-text">
            <span class="announcement-dot"></span>
            <span>Welcome To AurHER Store🤗</span>
            <span class="announcement-dot"></span>
        </div>
    </div>

  
    <header class="site-header">
        <div class="header-inner">

            <!-- Brand -->
            <a href="/" class="header-brand">
                <div class="header-brand-logo">
                    <img src="~/images/aurher-logo.png" alt="AurHER" />
                </div>
                <div class="header-brand-name">
                    <span class="aur">Aur</span><span class="her">HER</span>
                </div>
            </a>

           
            <nav class="header-nav">
                <a href="/" class="nav-link">Home</a>
                <a href="/Collection/PublicIndex" class="nav-link">Collections</a>
                <a href="/Category/PublicIndex" class="nav-link">Categories</a>
                <a href="/Track/Index" class="nav-link">Track Order</a>
            </nav>
        

         
            <div class="header-actions">

            <button class="header-btn" id="darkModeToggle" title="Toggle Dark Mode">
                <!-- Moon icon — shown in light mode -->
                <svg id="moonIcon" viewBox="0 0 24 24">
                    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                </svg>
                <!-- Sun icon — shown in dark mode -->
                <svg id="sunIcon" viewBox="0 0 24 24" style="display:none;">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="1" x2="12" y2="3"/>
                    <line x1="12" y1="21" x2="12" y2="23"/>
                    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                    <line x1="1" y1="12" x2="3" y2="12"/>
                    <line x1="21" y1="12" x2="23" y2="12"/>
                    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
            </button>
            
                <a href="/Cart" class="header-action-btn" title="Cart">
                    <svg viewBox="0 0 24 24">
                        <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <path d="M16 10a4 4 0 0 1-8 0"/>
                    </svg>
                    <span class="cart-badge hidden" id="cartBadge">0</span>
                </a>
  
            
                <button class="mobile-menu-btn" id="mobileMenuBtn" title="Menu">
                    <svg viewBox="0 0 24 24">
                        <line x1="3" y1="6" x2="21" y2="6"/>
                        <line x1="3" y1="12" x2="21" y2="12"/>
                        <line x1="3" y1="18" x2="21" y2="18"/>
                    </svg>
                </button>

            </div>
        </div>
    </header>


    <div class="mobile-nav" id="mobileNav">
        <div class="mobile-nav-overlay" id="mobileNavOverlay"></div>
        <div class="mobile-nav-drawer">
            <button class="mobile-nav-close" id="mobileNavClose">
                <svg viewBox="0 0 24 24">
                    <line x1="18" y1="6" x2="6" y2="18"/>
                    <line x1="6" y1="6" x2="18" y2="18"/>
                </svg>
            </button>
            <a href="/" class="mobile-nav-link">Home</a>
            <a href="/Collection/PublicIndex" class="mobile-nav-link">Collections</a>
            <a href="/Category/PublicIndex" class="mobile-nav-link">Categories</a>
            <a href="/Cart" class="mobile-nav-link">Cart</a>
            <a href="/Track/Index" class="mobile-nav-link">Track Order</a>
        </div>
    </div>
    
    <main class="site-main">
        @RenderBody()
    </main>

   
    <footer class="site-footer">
        <div class="footer-inner">
            <div class="footer-grid">

               
                <div>
                    <div class="footer-brand-name">
                        <span class="aur">Aur</span><span class="her">HER</span>
                    </div>
                    <p class="footer-brand-desc">
                        Premium women's fashion curated for the modern African woman.
                        Style that speaks before you do.
                    </p>
                    <div class="footer-social">
                       
                        <a href="#" class="footer-social-btn" title="Instagram">
                            <svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                        </a>
                        
                        <a href="#" class="footer-social-btn" title="Twitter">
                            <svg viewBox="0 0 24 24"><path d="M22 4s-.7 2.1-2 3.4c1.6 10-9.4 17.3-18 11.6 2.2.1 4.4-.6 6-2C3 15.5.5 9.6 3 5c2.2 2.6 5.6 4.1 9 4-.9-4.2 4-6.6 7-3.8 1.1 0 3-1.2 3-1.2z"/></svg>
                        </a>
                        
                        <a href="#" class="footer-social-btn" title="WhatsApp">
                            <svg viewBox="0 0 24 24"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
                        </a>
                    </div>
                </div>

              
                <div>
                    <div class="footer-col-title">Quick Links</div>
                    <ul class="footer-col-links">
                        <li><a href="/" class="footer-col-link">Home</a></li>
                        <li><a href="/Collection/PublicIndex" class="footer-col-link">Collections</a></li>
                        <li><a href="/Category/PublicIndex" class="footer-col-link">Categories</a></li>
                        <li><a href="/Cart" class="footer-col-link">Cart</a></li>
                    </ul>
                </div>


                <div>
                    <div class="footer-col-title">Customer Service</div>
                    <ul class="footer-col-links">
                        <li><a href="/Track/Index" class="footer-col-link">Track Order</a></li>
                        <li><a href="#" class="footer-col-link">FAQ</a></li>
                        <li><a href="#" class="footer-col-link">Returns Policy</a></li>
                        <li><a href="#" class="footer-col-link">Shipping Info</a></li>
                    </ul>
                </div>

             
                <div>
                    <div class="footer-col-title">Contact Us</div>
                    <ul class="footer-col-links">
                        <li>
                            <a href="#" class="footer-col-link">
                                AurHER.ng@gmail.com
                            </a>
                        </li>
                        <li>
                            <a href="https://wa.me/2348037089580" class="footer-col-link">
                                +234 8037089580
                            </a>
                        </li>
                        <li class="footer-col-link" style="cursor:default;">
                            Lagos Island, Lagos State, Nigeria
                        </li>
                    </ul>
                </div>

            </div>

         
            <div class="footer-bottom">
                <p class="footer-copyright">
                    
                    © @DateTime.Now.Year <span><a href="/Admin/login" >AurHER </a href> </span>. All rights reserved.
                    
                </p>
                <p class="footer-copyright">
                Looking to build a fast, scalable, modern website or app? 
                Work with Khaleed —Full-stack Developer. 
                
                <a href="https://wa.me/2349061421795" target="_blank">
                   Click here To Reach out on WhatsApp
                </a>.
                </p>

                <div class="footer-bottom-links">
                    <a href="#" class="footer-bottom-link">Privacy Policy</a>
                    <a href="#" class="footer-bottom-link">Terms of Service</a>
                </div>
            </div>

        </div>
    </footer>

    <script src="~/js/store.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>




