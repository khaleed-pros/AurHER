@model AurHER.DTOs.Admin.UpdateCollectionDto
@{
    ViewData["Title"] = "Edit Collection";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-collections.css" asp-append-version="true" />
}

<!-- ── Page Header ── -->
<div class="page-header animate-in">
    <h1 class="page-title">Edit Collection</h1>
    <p class="page-subtitle">Update collection information</p>
</div>

<!-- ── Form Card ── -->
<div class="form-card animate-in delay-1">
    <div class="form-card-header">
        <div>
            <div class="form-card-title">Collection Details</div>
            <div class="form-card-subtitle">Make your changes below</div>
        </div>
        <span class="editing-badge">
            <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Editing: @Model.Name
        </span>
    </div>
    <div class="form-card-body">

        <form method="post" asp-controller="Collection" asp-action="Edit">
            @Html.AntiForgeryToken()

            <input type="hidden" asp-for="Id" />

            <!-- Name -->
            <div class="form-group">
                <label class="form-label" asp-for="Name">
                    Collection Name <span>*</span>
                </label>
                <input type="text"
                       asp-for="Name"
                       class="form-input"
                       placeholder="e.g. Summer Collection, New Arrivals" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    Update Collection
                </button>
                <a href="/Collection/Index" class="btn-cancel">Cancel</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <script src="~/js/admin-collections.js" asp-append-version="true"></script>
}
