@model IEnumerable<AurHER.DTOs.Admin.CollectionDto>
@{
    ViewData["Title"] = "Collections";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-collections.css" asp-append-version="true" />
}

<!-- ── Page Header ── -->
<div class="page-actions animate-in">
    <div>
        <h1 class="page-title">Collections</h1>
        <p class="page-subtitle">Manage your product collections</p>
    </div>
    <a href="/Collection/Create" class="btn-add">
        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add Collection
    </a>
</div>

<!-- ── Alert Messages ── -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success animate-in">
        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-error animate-in">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        @TempData["ErrorMessage"]
    </div>
}

<!-- ── Collections Table ── -->
<div class="table-card animate-in delay-1">
    <div class="table-header">
        <span class="table-title">All Collections</span>
        <span class="table-count">@Model.Count() total</span>
    </div>

    @if (Model.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Collection</th>
                    <th>Products</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var collection in Model)
                {
                    <tr>
                        <td>
                            <div class="collection-name">@collection.Name</div>
                        </td>
                        <td>
                            <span class="product-badge">
                                @collection.ProductCount product@(collection.ProductCount != 1 ? "s" : "")
                            </span>
                        </td>
                        <td>
                            <div class="action-btns">
                                <a href="/Collection/Details/@collection.Id" class="btn-details">
                                    <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                    Manage
                                </a>
                                <a href="/Collection/Edit/@collection.Id" class="btn-edit">
                                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    Edit
                                </a>
                                <form method="post" action="/Collection/Delete" class="delete-form" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@collection.Id" />
                                    <button type="submit" class="btn-delete">
                                        <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <svg class="empty-icon" viewBox="0 0 24 24"><path d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            <div class="empty-title">No collections yet</div>
            <div class="empty-subtitle">Click "Add Collection" to create your first one</div>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/admin-collections.js" asp-append-version="true"></script>
}
