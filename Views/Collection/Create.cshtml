@model AurHER.DTOs.Admin.CreateCollectionDto
@{
    ViewData["Title"] = "Create Collection";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/admin-collections.css" asp-append-version="true" />
}

<!-- ── Page Header ── -->
<div class="page-header animate-in">
    <h1 class="page-title">Create Collection</h1>
    <p class="page-subtitle">Add a new collection to your store</p>
</div>

<!-- ── Form Card ── -->
<div class="form-card animate-in delay-1">
    <div class="form-card-header">
        <div>
            <div class="form-card-title">Collection Details</div>
            <div class="form-card-subtitle">Fill in the information below</div>
        </div>
    </div>
    <div class="form-card-body">

        <form method="post" asp-controller="Collection" asp-action="Create">
            @Html.AntiForgeryToken()

            <!-- Name -->
            <div class="form-group">
                <label class="form-label" asp-for="Name">
                    Collection Name <span>*</span>
                </label>
                <input type="text"
                       asp-for="Name"
                       class="form-input"
                       placeholder="e.g. Summer Collection, New Arrivals" />
                <span asp-validation-for="Name" class="field-error"></span>
            </div>

            <!-- Actions -->
            <div class="form-actions">
                <button type="submit" class="btn-save">
                    <svg viewBox="0 0 24 24"><path d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    Save Collection
                </button>
                <a href="/Collection/Index" class="btn-cancel">Cancel</a>
            </div>

        </form>

    </div>
</div>

@section Scripts {
    <script src="~/js/admin-collections.js" asp-append-version="true"></script>
}
