@model IEnumerable<AurHER.DTOs.Admin.CategoryDto>
@{
    ViewData["Title"] = "Categories";
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
}

@section Styles {
<link rel="stylesheet" href="~/css/admin-categories.css" />
}

<!-- ── Page Header ── -->
<div class="page-actions animate-in">
    <div>
        <h1 class="page-title">Categories</h1>
        <p class="page-subtitle">Manage your product categories</p>
    </div>
    <a href="/Category/Create" class="btn-add">
        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Add Category
    </a>
</div>

<!-- ── Alert Messages ── -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success animate-in">
        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
        @TempData["SuccessMessage"]
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-error animate-in">
        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        @TempData["ErrorMessage"]
    </div>
}

<!-- ── Categories Table ── -->
<div class="table-card animate-in delay-1">
    <div class="table-header">
        <span class="table-title">All Categories</span>
        <span class="table-count">@Model.Count() total</span>
    </div>

    @if (Model.Any())
    {
        <table class="data-table">
            <thead>
                <tr>
                    <th>Category</th>
                    <th>Products</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model)
                {
                    <tr>
                        <td>
                            <div class="category-name">@category.Name</div>
                            @if (!string.IsNullOrEmpty(category.Description))
                            {
                                <div class="category-desc">@category.Description</div>
                            }
                        </td>
                        <td>
                            <span class="product-badge">
                                @category.ProductCount product@(category.ProductCount != 1 ? "s" : "")
                            </span>
                        </td>
                        <td>
                            <div class="action-btns">
                                <a href="/Category/Edit/@category.Id" class="btn-edit">
                                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    Edit
                                </a>
                                <form method="post" action="/Category/Delete" class="delete-form" style="margin:0;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@category.Id" />
                                    <button type="submit" class="btn-delete">
                                        <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2"/></svg>
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <svg class="empty-icon" viewBox="0 0 24 24"><path d="M22 19a2 2 0 01-2 2H4a2 2 0 01-2-2V5a2 2 0 012-2h5l2 3h9a2 2 0 012 2z"/></svg>
            <div class="empty-title">No categories yet</div>
            <div class="empty-subtitle">Click "Add Category" to create your first one</div>
        </div>
    }
</div>

@section Scripts {
     <script src="~/js/admin-categories.js"></script>

}
